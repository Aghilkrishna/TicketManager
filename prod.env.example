# Database Configuration
DB_HOST=db
DB_PORT=5432
DB_NAME=ticketmanager
DB_USERNAME=your_db_username
DB_PASSWORD=your_db_password
DB_SSLMODE=disable
DB_CHANNEL_BINDING=disable

# JWT & Base URL
APP_JWT_SECRET=generate-a-long-random-string-here
APP_BASE_URL=http://your-vps-ip-or-domain:9090
APP_MAIL_ENABLED=true
APP_UPLOAD_DIR=uploads
APP_MASKING_ENABLED=false

# Mail Configuration (Example for Hostinger Port 465)
MAIL_HOST=smtp.hostinger.com
MAIL_PORT=465
MAIL_USERNAME=your-email@yourdomain.com
MAIL_PASSWORD=your-email-password
MAIL_SMTP_AUTH=true
MAIL_STARTTLS=false
MAIL_SSL_ENABLE=true
APP_MAIL_FROM_ADDRESS=noreplay@tickets.yubix.in
APP_MAIL_FROM_NAME=Ticket Manager

# Mail Configuration (Example for Gmail Port 587)
# MAIL_HOST=smtp.gmail.com
# MAIL_PORT=587
# MAIL_USERNAME=your-email@gmail.com
# MAIL_PASSWORD=your-app-password
# MAIL_SMTP_AUTH=true
# MAIL_STARTTLS=true
# MAIL_SSL_ENABLE=false
